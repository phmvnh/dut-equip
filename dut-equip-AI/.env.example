# Database (cùng MySQL với backend Spring Boot)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qltbc_draft
DB_USER=root
DB_PASSWORD=phmvnh

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# OpenWeather (hiện tại + dự báo 7 ngày + mật độ bụi qua Air Pollution API)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Da Nang,VN
# Toạ độ Đà Nẵng — dùng cho Air Pollution (bụi) và Open-Meteo (lịch sử 7/30 ngày, free, không cần key)
WEATHER_LAT=16.0544
WEATHER_LON=108.2022

# AI service
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_CRON_HOUR=7
AI_HISTORY_DAYS=90

# Backend Spring Boot được phép gọi vào /run, /predictions
ALLOWED_ORIGINS=http://localhost:8080
