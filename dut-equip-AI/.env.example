# File MẪU — copy thành `.env` rồi điền khóa thật. KHÔNG điền khóa thật vào file này.

# Database (cùng MySQL với backend Spring Boot)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dut_equip
DB_USER=root
DB_PASSWORD=your-db-password

# Gemini — lấy khóa tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# OpenWeather (hiện tại + dự báo 7 ngày + mật độ bụi qua Air Pollution API)
# Lấy khóa tại https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_CITY=Da Nang,VN
# Toạ độ Đà Nẵng — dùng cho Air Pollution (bụi) và Open-Meteo (lịch sử 7/30 ngày, free, không cần key)
WEATHER_LAT=16.0544
WEATHER_LON=108.2022

# AI service
# Lịch chạy 7h sáng do Windows Task Scheduler (run_once.py) đảm nhiệm, không cấu hình ở đây.
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_HISTORY_DAYS=90

# Backend Spring Boot được phép gọi vào /run, /predictions
ALLOWED_ORIGINS=http://localhost:8080
