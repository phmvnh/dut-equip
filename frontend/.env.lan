# Dùng khi chạy `npm run dev:lan` để các máy/điện thoại khác trong LAN truy cập được.
# Nếu IP LAN của máy chủ thay đổi (đổi WiFi, restart router) -> chạy `ipconfig` xem IPv4 mới
# rồi cập nhật 2 dòng dưới đây.
# VITE_API_BASE_URL=http://192.168.1.159:8080/api/v1
# VITE_WS_BASE_URL=http://192.168.1.159:8080


VITE_API_BASE_URL=http://172.16.51.223:8080/api/v1
VITE_WS_BASE_URL=http://172.16.51.223:8080